{
  "name": "dslforge",
  "displayName": "DSLForge",
  "description": "DSL authoring workflow assistant for Visual Studio Code, starting with Langium.",
  "version": "0.0.1",
  "publisher": "emfpdlzj",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [],
  "main": "dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "DSLForge",
      "properties": {
        "dslforge.validation.command": {
          "type": "string",
          "default": "",
          "markdownDescription": "Workspace validation command used first by `DSLForge: Validate Current Grammar`. If empty, DSLForge auto-detects a supported `package.json` script."
        }
      }
    },
    "commands": [
      {
        "command": "dslforge.createDslScaffold",
        "title": "DSLForge: Create DSL Scaffold",
        "category": "DSLForge"
      },
      {
        "command": "dslforge.generateSampleDsl",
        "title": "DSLForge: Generate Sample DSL",
        "category": "DSLForge"
      },
      {
        "command": "dslforge.validateCurrentGrammar",
        "title": "DSLForge: Validate Current Grammar",
        "category": "DSLForge"
      },
      {
        "command": "dslforge.explainCurrentGrammar",
        "title": "DSLForge: Explain Current Grammar",
        "category": "DSLForge"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emfpdlzj/DSLForge.git"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/emfpdlzj/DSLForge/issues"
  },
  "homepage": "https://github.com/emfpdlzj/DSLForge#readme",
  "devDependencies": {
    "@types/node": "^24.13.1",
    "@types/vscode": "^1.120.0",
    "typescript": "^6.0.3"
  }
}
