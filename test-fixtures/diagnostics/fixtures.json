{
  "workspaceRoot": "test-fixtures/langium/import-context",
  "fixtures": [
    {
      "name": "generic-typescript-unlocated",
      "parser": "generic",
      "logFile": "test-fixtures/diagnostics/generic-typescript-unlocated.log",
      "defaultSource": "Langium",
      "expectedIssues": [
        {
          "severity": "error",
          "source": "TypeScript",
          "code": "TS2345",
          "messageIncludes": "Argument of type 'string' is not assignable to parameter of type 'number'"
        }
      ]
    },
    {
      "name": "langium-webpack-tsl-block",
      "parser": "langium",
      "logFile": "test-fixtures/diagnostics/langium-webpack-tsl-block.log",
      "expectedIssues": [
        {
          "severity": "error",
          "source": "TypeScript",
          "code": "TS2322",
          "filePath": "src/language/main.langium",
          "line": 5,
          "column": 12,
          "messageIncludes": "Type 'number' is not assignable to type 'string'"
        }
      ]
    },
    {
      "name": "langium-unlocated-reference",
      "parser": "langium",
      "logFile": "test-fixtures/diagnostics/langium-unlocated-reference.log",
      "expectedIssues": [
        {
          "severity": "error",
          "source": "Langium",
          "messageIncludes": "Could not resolve reference to Type 'MissingRule'"
        }
      ]
    },
    {
      "name": "langium-config-failure",
      "parser": "langium",
      "logFile": "test-fixtures/diagnostics/langium-config-failure.log",
      "expectedIssues": [
        {
          "severity": "error",
          "source": "Langium",
          "messageIncludes": "Failed to read langium-config.json because the JSON is invalid"
        }
      ]
    },
    {
      "name": "antlr4-located-error",
      "parser": "antlr4",
      "workspaceRoot": "test-fixtures/antlr4/package-script",
      "activeGrammarFile": "src/grammar/Expr.g4",
      "logFile": "test-fixtures/diagnostics/antlr4-located-error.log",
      "expectedIssues": [
        {
          "severity": "error",
          "source": "ANTLR4",
          "code": "ANTLR50",
          "filePath": "src/grammar/Expr.g4",
          "line": 3,
          "column": 1,
          "messageIncludes": "syntax error: missing ';' at 'options'"
        }
      ]
    },
    {
      "name": "antlr4-active-file-error",
      "parser": "antlr4",
      "workspaceRoot": "test-fixtures/antlr4/package-script",
      "activeGrammarFile": "src/grammar/Expr.g4",
      "logFile": "test-fixtures/diagnostics/antlr4-active-file-error.log",
      "expectedIssues": [
        {
          "severity": "error",
          "source": "ANTLR4",
          "filePath": "src/grammar/Expr.g4",
          "line": 5,
          "column": 1,
          "messageIncludes": "token recognition error at: '$'"
